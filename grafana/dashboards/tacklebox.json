{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "id": 1,
      "title": "Active Sessions",
      "type": "stat",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "targets": [
        {
          "rawSql": "SELECT count(*) as \"Active Sessions\" FROM sessions WHERE status = 'active';",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 9,
      "title": "Avg Session Duration",
      "type": "stat",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "m"
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT ROUND(AVG(EXTRACT(EPOCH FROM (ended_at - started_at)) / 60)::numeric, 1) as \"Avg Duration (min)\" FROM sessions WHERE ended_at IS NOT NULL AND $__timeFilter(started_at);",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Sessions per Hour",
      "type": "barchart",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "stacking": "normal",
        "barWidth": 0.8,
        "orientation": "vertical",
        "xTickLabelRotation": -45
      },
      "targets": [
        {
          "rawSql": "SELECT to_char(date_trunc('hour', started_at), 'MM-DD HH24:00') as hour, count(*) as sessions FROM sessions WHERE $__timeFilter(started_at) GROUP BY hour ORDER BY hour;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Tool Usage",
      "type": "barchart",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "rawSql": "SELECT tool_name, count(*) as invocations FROM tool_events WHERE $__timeFilter(created_at) GROUP BY tool_name ORDER BY invocations DESC;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 10,
      "title": "Tool Usage Over Time",
      "type": "timeseries",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "stacking": { "mode": "normal" },
            "fillOpacity": 80,
            "barAlignment": 0
          }
        },
        "overrides": []
      },
      "targets": [
        {
          "rawSql": "SELECT date_trunc('hour', created_at) as time, tool_name, count(*) as invocations FROM tool_events WHERE $__timeFilter(created_at) GROUP BY time, tool_name ORDER BY time;",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Tool Failures",
      "type": "table",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "rawSql": "SELECT te.created_at as time, s.cc_session_id as session, te.tool_name, COALESCE(te.error, te.tool_response->>'error', 'unknown') as error_message FROM tool_events te JOIN sessions s ON s.id = te.session_id WHERE te.hook_event = 'PostToolUseFailure' AND $__timeFilter(te.created_at) ORDER BY te.created_at DESC LIMIT 50;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 11,
      "title": "Sessions by Directory",
      "type": "table",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "rawSql": "SELECT cwd as directory, count(*) as total_sessions, count(*) FILTER (WHERE status = 'active') as active FROM sessions WHERE $__timeFilter(started_at) GROUP BY cwd ORDER BY total_sessions DESC LIMIT 20;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "File Lock Warnings",
      "type": "table",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "rawSql": "SELECT te.created_at as time, s.cc_session_id as session, te.tool_input->>'file_path' as file, te.decision as action FROM tool_events te JOIN sessions s ON s.id = te.session_id WHERE te.decision = 'warn' AND $__timeFilter(te.created_at) ORDER BY te.created_at DESC LIMIT 50;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Stop Blocks",
      "type": "table",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "reason" },
            "properties": [
              { "id": "custom.width", "value": 400 }
            ]
          }
        ]
      },
      "targets": [
        {
          "rawSql": "SELECT sb.created_at as time, s.cc_session_id as session, REPLACE(REPLACE(sb.reason, '[{''', ''), '''}]', '') as reason FROM stop_blocks sb JOIN sessions s ON s.id = sb.session_id WHERE $__timeFilter(sb.created_at) ORDER BY sb.created_at DESC LIMIT 50;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Notification Types",
      "type": "barchart",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        {
          "rawSql": "SELECT notification_type, count(*) as total FROM notifications WHERE $__timeFilter(created_at) GROUP BY notification_type ORDER BY total DESC;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "title": "Subagent Activity",
      "type": "barchart",
      "datasource": { "type": "grafana-postgresql-datasource", "uid": "P8486BE4CAA945761" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        {
          "rawSql": "SELECT agent_type, count(*) as spawns FROM subagent_events WHERE hook_event = 'SubagentStart' AND $__timeFilter(created_at) GROUP BY agent_type ORDER BY spawns DESC;",
          "format": "table",
          "refId": "A"
        }
      ]
    }
  ],
